# Claude CLI
ANTHROPIC_API_KEY=sk-ant-...
{% if cookiecutter.enable_slack_mcp == "yes" %}
# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_TEAM_ID={{ cookiecutter.slack_team_id }}
{% endif %}{% if cookiecutter.enable_telegram_mcp == "yes" %}
# Telegram
TELEGRAM_BOT_TOKEN={{ cookiecutter.telegram_bot_token }}
{% endif %}{% if cookiecutter.enable_postgres_mcp == "yes" %}
# PostgreSQL
DATABASE_URL={{ cookiecutter.postgres_connection_string }}
{% endif %}{% if cookiecutter.enable_jira_mcp == "yes" %}
# Jira
JIRA_URL={{ cookiecutter.jira_instance_url }}
JIRA_API_TOKEN=...
JIRA_PROJECT_KEY={{ cookiecutter.jira_project_key }}
{% endif %}{% if cookiecutter.enable_github_mcp == "yes" %}
# GitHub
GITHUB_TOKEN=ghp_...
{% endif %}
