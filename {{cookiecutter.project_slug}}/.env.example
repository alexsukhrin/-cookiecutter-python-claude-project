# Claude CLI
ANTHROPIC_API_KEY=sk-ant-...
{% if cookiecutter.enable_slack_mcp == "yes" %}
# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_TEAM_ID={{ cookiecutter.slack_team_id }}
{% endif %}{% if cookiecutter.enable_telegram_mcp == "yes" %}
# Telegram
TELEGRAM_BOT_TOKEN={{ cookiecutter.telegram_bot_token }}
TELEGRAM_CHAT_ID=
{% endif %}{% if cookiecutter.enable_linear_mcp == "yes" %}
# Linear
LINEAR_API_KEY=lin_api_...
{% endif %}{% if cookiecutter.enable_postgres_mcp == "yes" %}
# PostgreSQL
DATABASE_URL={{ cookiecutter.postgres_connection_string }}
{% endif %}{% if cookiecutter.enable_jira_mcp == "yes" %}
# Jira
JIRA_URL={{ cookiecutter.jira_instance_url }}
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=...
JIRA_PROJECT_KEY={{ cookiecutter.jira_project_key }}
JIRA_ASSIGNEE={{ cookiecutter.jira_assignee }}
{% endif %}{% if cookiecutter.enable_confluence_mcp == "yes" %}
# Confluence
CONFLUENCE_URL={{ cookiecutter.confluence_url }}
CONFLUENCE_USER_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=...
CONFLUENCE_SPACE_KEY={{ cookiecutter.confluence_space_key }}
{% endif %}{% if cookiecutter.enable_github_mcp == "yes" %}
# GitHub
GITHUB_TOKEN=ghp_...
{% endif %}
